tion\": \"javascript-only\"\n}\n"}},{"timestamp":1772638553240,"editorVersion":"4.0.10","text":{"main.ts":"namespace Quiltflower {\r\n    export let testCart:Emulator.Cartidge = Emulator.bootstrapNew(\"test\", 0);\r\n    Emulator.loadAll();\r\n\r\n    game.showLongText(Emulator.cartStrings, DialogLayout.Bottom);\r\n\r\n    \r\n}","README.md":" ","assets.json":"","emulatedGame.ts":"namespace Emulator {\n    export let carts: Cartidge[] = [];\n    export let cartStrings: String[] = [];\n\n    export class Cartidge {\n        _name: string; // The string id\n        _id: number; // The numerical id of the cartridge. Should be higher than 0\n\n        constructor(_name: string, _id: number) {\n            this._name = _name;\n            this._id = _id;\n        }\n\n        get name(): string {\n            return this._name;\n        }\n\n        get id(): number {\n            return this._id;\n        }\n\n        set name(input: string) {\n            this._name = input;\n        }\n\n        set id(input: number) {\n            this._id = input;\n        }\n    }\n\n    export function bootstrapNew(name: string, id: number): Cartidge {\n        const cart = new Cartidge(name, id);\n        carts.push(cart);\n        cartStrings.push(name);\n        return cart;\n    }\n\n    export function loadAll(): void {\n\n        try {\n            for (let value of carts) {\n                const valueName: string = value.name;\n                const valueId: number = value.id;\n\n                console.log(\"Loaded cart: \" + valueName + \" with ID: \" + valueId);\n            }\n        } catch {\n\n        }\n    }\n}","pxt.json":"{\n    \"name\": \"Quiltflower\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"emulatedGame.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"languageRestriction\": \"javascript-only\"\n}\n"}},{"timestamp":1772640360984,"editorVersion":"4.0.10","text":{"main.ts":"namespace Quiltflower {\r\n    export let testCart:Emulator.Cartidge = Emulator.bootstrapNew(\"test\", 0);\r\n    export let secondCart:Emulator.Cartidge = Emulator.bootstrapNew(\"secondTest\", 1);\r\n\r\n    Emulator.checkAllTest();\r\n    game.showLongText(Emulator.cartStrings, DialogLayout.Bottom);\r\n\r\n    Emulator.loadCart(testCart);\r\n}","README.md":" ","assets.json":"","emulatedGame.ts":"namespace Emulator {\n    export let carts: Cartidge[] = [];\n    export let cartStrings: String[] = [];\n    export let loadedCart:Cartidge;\n\n    export class Cartidge {\n        _name: string; // The string id\n        _id: number; // The numerical id of the cartridge. Should be higher than 0\n\n        constructor(_name: string, _id: number) {\n            this._name = _name;\n            this._id = _id;\n        }\n\n        get name(): string {\n            return this._name;\n        }\n\n        get id(): number {\n            return this._id;\n        }\n\n        set name(input: string) {\n            this._name = input;\n        }\n\n        set id(input: number) {\n            this._id = input;\n        }\n\n        onLoad(handler: () => void) {\n            control.onEvent(this.id, this.id, handler);\n        }\n    }\n\n    export function bootstrapNew(name: string, id: number): Cartidge {\n        const cart = new Cartidge(name, id);\n        carts.push(cart);\n        cartStrings.push(name);\n        return cart;\n    }\n\n    export function checkAllTest(): void {\n        let loadedCart:Cartidge;\n        let cardIDS = [];\n        let count = 0;\n\n        try {\n            for (let value of carts) {\n                count++;\n                const valueName: string = value.name;\n                const valueId: number = value.id;\n\n                console.log(\"Loaded cart: \" + valueName + \" with ID: \" + valueId);\n                loadedCart = value;\n                cardIDS.push(valueId);\n            }\n        } catch {\n            crash(loadedCart);\n        }\n    }\n\n    function crash(cart:Cartidge) {\n        control.fail(\"Failed to load cart: \" + cart.name);\n    }\n\n    export function getLoadedCart(): Cartidge {\n        return loadedCart;\n    }\n\n    export function loadCart(cart: Cartidge): void {\n        loadedCart = cart;\n        cart.onLoad(function() {\n\n        })\n    }\n\n    \n}\n\n// onEvent(event: ControllerEvent, handler: () => void) {\n//     control.onEvent(this.id, event, handler);\n// }","pxt.json":"{\n    \"name\": \"Quiltflower\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"emulatedGame.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"languageRestriction\": \"javascript-only\"\n}\n"}}],"shares":[],"lastSaveTime":1772641848102}